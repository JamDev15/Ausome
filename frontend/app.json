{
  "expo": {
    "name": "Ausome",
    "slug": "ausome",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#EAF1FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ausome.app",
      "deploymentTarget": "14.0",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used for recording custom voice prompts",
        "NSSpeechRecognitionUsageDescription": "Used for voice input support",
        "NSPhotoLibraryUsageDescription": "Used for uploading child photos and AAC images",
        "NSCameraUsageDescription": "Used for taking photos for child profiles"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#F6F9FF",
      "barStyle": "dark-content",
      "translucent": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B8DEF"
      },
      "package": "com.ausome.app",
      "targetSdkVersion": 34,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-av",
      [
        "expo-image-picker",
        {
          "photosPermission": "Used for child profiles and AAC boards"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/app-icon.png",
          "color": "#5B8DEF",
          "sounds": [],
          "iosDisplayInForeground": true
        }
      ]
    ],
    "scheme": "ausome",
    "extra": {
      "eas": {
        "projectId": "0e0b83a2-5096-4728-bc02-1956bfffd6a6"
      }
    },
    "owner": "jeyemmdev"
  }
}
