# Application
APP_NAME=EboyApp
APP_ENV=development
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
DEBUG=true

# MongoDB
MONGO_USER=eboyapp
MONGO_PASSWORD=eboyapp_secret
MONGO_DB=eboyapp
MONGODB_URL=mongodb://eboyapp:eboyapp_secret@localhost:27017/eboyapp?authSource=admin
MONGODB_DB=eboyapp

# Redis
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# Email (configure for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=noreply@eboyapp.com
EMAILS_FROM_NAME=EboyApp

# AI (optional - configure when ready)
OPENAI_API_KEY=sk-...
AI_ENABLED=false
AI_MODEL=gpt-4o

# Media / Storage
MEDIA_BASE_URL=http://localhost:8000/media
MAX_UPLOAD_SIZE_MB=10

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","exp://localhost:8081"]

# Admin
FIRST_ADMIN_EMAIL=admin@eboyapp.com
FIRST_ADMIN_PASSWORD=Admin123!
